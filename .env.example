# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Docker & Local)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=classroom_quiz
POSTGRES_PORT=5432

# Connection string used by Prisma.
# For local development (server running on host, postgres in Docker):
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/classroom_quiz?schema=public"

# For docker-compose deployment (server running in Docker):
# DATABASE_URL="postgresql://postgres:postgres_password@db:5432/classroom_quiz?schema=public"

# Authentication
JWT_SECRET="classroom_quiz_super_secret_jwt_token_key_change_me_in_production"
JWT_EXPIRES_IN="7d"

# Security & CORS
CORS_ORIGIN="http://localhost:5173"
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX=100          # Limit each IP to 100 requests per window
